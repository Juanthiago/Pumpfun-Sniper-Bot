# Solana RPC URL
# Use a reliable RPC provider like Helius, QuickNode, or Alchemy for better performance
RPC_URL=https://api.mainnet-beta.solana.com

# Private Key (Base58 string or JSON array)
# IMPORTANT: Never commit your actual private key to version control!
# Format options:
# 1. Base58 string: "your_base58_private_key_here"
# 2. JSON array: "[1,2,3,...]" (array of numbers)
PRIVATE_KEY=

# Blocklist file path
# File containing wallet addresses to block (one per line)
BLOCKLIST_PATH=./blocklist.txt

# Trading Parameters
# Stop loss percentage (e.g., 10 = 10% loss triggers sell)
STOP_LOSS_PERCENT=10

# Take profit percentage (e.g., 50 = 50% gain triggers sell)
TAKE_PROFIT_PERCENT=50

# Buy amount in SOL (e.g., 0.1 = 0.1 SOL per trade)
BUY_AMOUNT=0.1

# Slippage tolerance percentage (e.g., 5 = 5% slippage allowed)
SLIPPAGE=5
